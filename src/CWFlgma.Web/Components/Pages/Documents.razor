@page "/documents"
@using System.Net.Http.Json
@using Microsoft.JSInterop
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>文档 - CWFlgma</PageTitle>

<div class="documents-page">
    <div class="page-header">
        <div class="header-left">
            <h1>我的文档</h1>
            <span class="doc-count">@documents.Count 个文档</span>
        </div>
        <button class="btn btn-primary" @onclick="() => showCreateForm = true">
            <span>+</span>
            <span>新建文档</span>
        </button>
    </div>
    
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">
            <span>⚠</span>
            <span>@errorMessage</span>
            <button class="alert-close" @onclick="() => errorMessage = null">×</button>
        </div>
    }
    
    @if (!string.IsNullOrEmpty(debugInfo))
    {
        <div class="alert alert-info">
            <small>@debugInfo</small>
        </div>
    }
    
    @if (showCreateForm)
    {
        <div class="modal-overlay" @onclick="() => showCreateForm = false">
            <div class="modal-content" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h3>新建文档</h3>
                    <button class="modal-close" @onclick="() => showCreateForm = false">×</button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label>文档标题</label>
                        <input type="text" @bind="newTitle" placeholder="请输入文档标题" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>文档描述</label>
                        <textarea @bind="newDescription" placeholder="请输入文档描述（可选）" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="form-group">
                        <label>文档类型</label>
                        <select @bind="newType" class="form-control">
                            <option value="design">设计稿</option>
                            <option value="prototype">原型</option>
                            <option value="whiteboard">白板</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showCreateForm = false">取消</button>
                    <button class="btn btn-primary" @onclick="CreateDocument" disabled="@isCreating">
                        @if (isCreating)
                        {
                            <span class="spinner"></span>
                        }
                        <span>创建</span>
                    </button>
                </div>
            </div>
        </div>
    }
    
    <div class="documents-grid">
        @if (isLoading)
        {
            <div class="loading-state">
                <div class="spinner-large"></div>
                <p>加载中...</p>
            </div>
        }
        else if (documents.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-icon">📁</div>
                <h3>暂无文档</h3>
                <p>点击"新建文档"创建您的第一个设计</p>
                <button class="btn btn-primary" @onclick="() => showCreateForm = true">创建文档</button>
            </div>
        }
        else
        {
            @foreach (var doc in documents)
            {
                <div class="document-card">
                    <div class="document-thumbnail" style="background-color: @doc.BackgroundColor">
                        <div class="doc-type-icon">
                            @if (doc.Type == "folder")
                            {
                                <span>📁</span>
                            }
                            else
                            {
                                <span>🎨</span>
                            }
                        </div>
                    </div>
                    <div class="document-info">
                        <a href="/documents/@doc.Id" class="document-title">@doc.Title</a>
                        <p class="document-meta">
                            @doc.Type • 版本 @doc.Version
                        </p>
                        <p class="document-time">@FormatTime(doc.UpdatedAt)</p>
                    </div>
                    <div class="document-actions">
                        <a href="/documents/@doc.Id" class="btn btn-icon" title="打开">
                            📂
                        </a>
                        @if (doc.Permission == "owner")
                        {
                            <button class="btn btn-icon btn-danger-icon" title="删除" @onclick="() => DeleteDocument(doc.Id)">
                                🗑
                            </button>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    private List<DocumentDto> documents = new();
    private bool isLoading = true;
    private bool isCreating;
    private bool showCreateForm;
    private string? errorMessage;
    private string? debugInfo;
    private string newTitle = "";
    private string newDescription = "";
    private string newType = "design";

    protected override async Task OnInitializedAsync()
    {
        await CheckAuthAndLoadDocuments();
    }

    private async Task CheckAuthAndLoadDocuments()
    {
        try
        {
            var token = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "authToken");
            if (string.IsNullOrEmpty(token))
            {
                debugInfo = "未登录，正在跳转到登录页面...";
                StateHasChanged();
                await Task.Delay(1000);
                Navigation.NavigateTo("/login");
                return;
            }
            
            await LoadDocuments(token);
        }
        catch (Exception ex)
        {
            errorMessage = $"初始化失败: {ex.Message}";
        }
    }

    private async Task LoadDocuments(string token)
    {
        isLoading = true;
        debugInfo = "正在加载文档列表...";
        StateHasChanged();
        
        try
        {
            var client = HttpClientFactory.CreateClient("DocumentService");
            
            // 手动添加 Authorization header
            client.DefaultRequestHeaders.Authorization = 
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            
            debugInfo = $"请求: {client.BaseAddress}api/documents";
            StateHasChanged();
            
            var response = await client.GetAsync("/api/documents");
            
            debugInfo = $"响应状态: {response.StatusCode}";
            StateHasChanged();
            
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<List<DocumentDto>>();
                documents = result ?? new();
                debugInfo = $"加载了 {documents.Count} 个文档";
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                errorMessage = "登录已过期，请重新登录";
                await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "authToken");
                Navigation.NavigateTo("/login");
            }
            else
            {
                errorMessage = $"加载失败: {response.StatusCode}";
            }
        }
        catch (HttpRequestException ex)
        {
            errorMessage = $"网络错误: {ex.Message}";
            debugInfo = "请检查 DocumentService 是否正常运行";
        }
        catch (Exception ex)
        {
            errorMessage = $"加载失败: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task CreateDocument()
    {
        if (string.IsNullOrWhiteSpace(newTitle))
        {
            errorMessage = "请输入文档标题";
            return;
        }

        isCreating = true;
        StateHasChanged();

        try
        {
            var token = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "authToken");
            var client = HttpClientFactory.CreateClient("DocumentService");
            client.DefaultRequestHeaders.Authorization = 
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            
            var response = await client.PostAsJsonAsync("/api/documents", new
            {
                title = newTitle,
                description = newDescription,
                type = newType,
                width = 1920,
                height = 1080,
                backgroundColor = "#FFFFFF"
            });

            if (response.IsSuccessStatusCode)
            {
                showCreateForm = false;
                newTitle = "";
                newDescription = "";
                await LoadDocuments(token);
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                errorMessage = $"创建失败: {error}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"创建失败: {ex.Message}";
        }
        finally
        {
            isCreating = false;
            StateHasChanged();
        }
    }

    private async Task DeleteDocument(long id)
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", "确定要删除这个文档吗？")) 
            return;
        
        try
        {
            var token = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "authToken");
            var client = HttpClientFactory.CreateClient("DocumentService");
            client.DefaultRequestHeaders.Authorization = 
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            
            await client.DeleteAsync($"/api/documents/{id}");
            await LoadDocuments(token);
        }
        catch (Exception ex)
        {
            errorMessage = $"删除失败: {ex.Message}";
        }
    }

    private string FormatTime(DateTime time)
    {
        var diff = DateTime.UtcNow - time;
        if (diff.TotalMinutes < 1) return "刚刚";
        if (diff.TotalHours < 1) return $"{(int)diff.TotalMinutes} 分钟前";
        if (diff.TotalDays < 1) return $"{(int)diff.TotalHours} 小时前";
        return time.ToString("MM-dd HH:mm");
    }

    private class DocumentDto
    {
        public long Id { get; set; }
        public string Title { get; set; } = "";
        public string Type { get; set; } = "";
        public string BackgroundColor { get; set; } = "#FFFFFF";
        public int Version { get; set; }
        public DateTime UpdatedAt { get; set; }
        public string? Permission { get; set; }
    }
}
