@page "/login"
@using System.Net.Http.Json
@using Microsoft.JSInterop
@using Microsoft.Extensions.Logging
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject ILogger<Login> Logger
@inject IConfiguration Configuration

<PageTitle>登录 - CWFlgma</PageTitle>

<div class="login-wrapper">
    <div class="animated-bg">
        <div class="gradient-sphere sphere-1"></div>
        <div class="gradient-sphere sphere-2"></div>
        <div class="gradient-sphere sphere-3"></div>
    </div>
    
    <div class="login-container">
        <div class="login-card">
            <div class="login-header">
                <div class="logo-container">
                    <div class="logo-glow"></div>
                    <svg class="logo" width="64" height="64" viewBox="0 0 64 64" fill="none">
                        <defs>
                            <linearGradient id="logoGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" style="stop-color:#7C3AED"/>
                                <stop offset="100%" style="stop-color:#EC4899"/>
                            </linearGradient>
                        </defs>
                        <rect width="64" height="64" rx="16" fill="url(#logoGradient)"/>
                        <path d="M32 16L44 28V44L32 56L20 44V28L32 16Z" fill="white" opacity="0.9"/>
                        <path d="M32 24L38 30V42L32 48L26 42V30L32 24Z" fill="url(#logoGradient)"/>
                    </svg>
                </div>
                <h1>CWFlgma</h1>
                <p>下一代协作设计平台</p>
            </div>
            
            <div class="form-section">
                <div class="input-group">
                    <div class="input-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                            <polyline points="22,6 12,13 2,6"/>
                        </svg>
                    </div>
                    <input id="email" type="email" @bind="email" @bind:event="oninput" 
                           placeholder="邮箱地址" class="form-input" />
                </div>
                
                <div class="input-group">
                    <div class="input-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                        </svg>
                    </div>
                    <input id="password" type="password" @bind="password" @bind:event="oninput" 
                           placeholder="密码" class="form-input"
                           @onkeypress="@(e => { if (e.Key == "Enter") _ = HandleLogin(); })" />
                </div>
                
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-error">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="15" y1="9" x2="9" y2="15"/>
                            <line x1="9" y1="9" x2="15" y2="15"/>
                        </svg>
                        <span>@errorMessage</span>
                    </div>
                }
                
                <button class="btn-login" @onclick="HandleLogin" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <div class="spinner"></div>
                        <span>正在连接...</span>
                    }
                    else
                    {
                        <span>登 录</span>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="5" y1="12" x2="19" y2="12"/>
                            <polyline points="12 5 19 12 12 19"/>
                        </svg>
                    }
                </button>
            </div>
            
            <div class="quick-login-section">
                <div class="divider">
                    <span>快速登录</span>
                </div>
                <div class="quick-login-buttons">
                    <button class="btn-quick" @onclick="QuickLoginAdmin">
                        <div class="btn-quick-icon admin">👨‍💼</div>
                        <div class="btn-quick-text">
                            <span class="btn-quick-title">管理员</span>
                            <span class="btn-quick-desc">admin@cwflgma.com</span>
                        </div>
                    </button>
                    <button class="btn-quick" @onclick="QuickLoginDemo">
                        <div class="btn-quick-icon demo">👤</div>
                        <div class="btn-quick-text">
                            <span class="btn-quick-title">演示用户</span>
                            <span class="btn-quick-desc">demo@cwflgma.com</span>
                        </div>
                    </button>
                </div>
            </div>
            
            <div class="login-footer">
                <a href="/" class="footer-link">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="19" y1="12" x2="5" y2="12"/>
                        <polyline points="12 19 5 12 12 5"/>
                    </svg>
                    <span>返回首页</span>
                </a>
                <a href="https://localhost:17193" target="_blank" class="footer-link">
                    <span>Aspire Dashboard</span>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                        <polyline points="15 3 21 3 21 9"/>
                        <line x1="10" y1="14" x2="21" y2="3"/>
                    </svg>
                </a>
            </div>
            
            <!-- Debug Panel -->
            <div class="debug-toggle" @onclick="() => showDebug = !showDebug">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="16" x2="12" y2="12"/>
                    <line x1="12" y1="8" x2="12.01" y2="8"/>
                </svg>
                <span>调试信息 @(showDebug ? "▼" : "▶")</span>
            </div>
            
            @if (showDebug)
            {
                <div class="debug-panel">
                    <div class="debug-content">
                        @if (debugLogs.Count == 0)
                        {
                            <div class="debug-empty">点击登录按钮查看调试信息</div>
                        }
                        @foreach (var log in debugLogs)
                        {
                            <div class="debug-log @log.Type">
                                <span class="debug-time">@log.Time</span>
                                <span class="debug-msg">@log.Message</span>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private string email = "admin@cwflgma.com";
    private string password = "Admin@123456";
    private string? errorMessage;
    private bool isLoading;
    private bool showDebug = true;
    private List<DebugLog> debugLogs = new();

    private void AddLog(string message, string type = "info")
    {
        var log = new DebugLog
        {
            Time = DateTime.Now.ToString("HH:mm:ss.fff"),
            Message = message,
            Type = type
        };
        debugLogs.Add(log);
        Logger.LogInformation("[Login] {Message}", message);
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        AddLog("页面初始化完成", "info");
        
        // 输出配置信息
        var services = Configuration.GetSection("services");
        foreach (var section in services.GetChildren())
        {
            AddLog($"服务配置: {section.Key}", "debug");
        }
    }

    private async Task HandleLogin()
    {
        errorMessage = null;
        debugLogs.Clear();
        isLoading = true;
        
        AddLog("===== 开始登录流程 =====", "info");
        AddLog($"账号: {email}", "info");
        
        try
        {
            // 1. 获取 HttpClient
            AddLog("步骤 1: 创建 HttpClient...", "info");
            
            HttpClient client;
            try
            {
                client = HttpClientFactory.CreateClient("UserService");
                AddLog($"HttpClient 创建成功", "success");
            }
            catch (Exception ex)
            {
                AddLog($"HttpClient 创建失败: {ex.Message}", "error");
                errorMessage = "无法创建 HTTP 客户端";
                return;
            }
            
            var baseUrl = client.BaseAddress?.ToString() ?? "未设置";
            AddLog($"BaseAddress: {baseUrl}", "info");
            
            // 2. 构建请求
            var loginUrl = "/api/auth/login";
            var fullUrl = $"{baseUrl.TrimEnd('/')}{loginUrl}";
            AddLog($"请求 URL: {fullUrl}", "info");
            
            // 3. 发送请求
            AddLog("步骤 2: 发送登录请求...", "info");
            var startTime = DateTime.UtcNow;
            
            HttpResponseMessage response;
            try
            {
                var requestData = new { email, password };
                AddLog($"请求数据: {{ email: \"{email}\", password: \"***\" }}", "debug");
                
                response = await client.PostAsJsonAsync(loginUrl, requestData);
                var elapsed = DateTime.UtcNow - startTime;
                AddLog($"请求完成，耗时: {elapsed.TotalMilliseconds:F0}ms", "success");
            }
            catch (HttpRequestException ex)
            {
                AddLog($"网络异常: {ex.Message}", "error");
                if (ex.InnerException != null)
                {
                    AddLog($"内部异常: {ex.InnerException.Message}", "error");
                }
                errorMessage = $"网络错误: {ex.Message}";
                return;
            }
            catch (TaskCanceledException)
            {
                AddLog("请求超时 (30秒)", "error");
                errorMessage = "请求超时，请检查网络连接";
                return;
            }
            catch (Exception ex)
            {
                AddLog($"未知异常: {ex.GetType().Name}: {ex.Message}", "error");
                errorMessage = $"请求失败: {ex.Message}";
                return;
            }
            
            // 4. 处理响应
            AddLog($"步骤 3: 处理响应", "info");
            AddLog($"状态码: {response.StatusCode} ({(int)response.StatusCode})", "info");
            
            var content = await response.Content.ReadAsStringAsync();
            AddLog($"响应长度: {content.Length} 字符", "debug");
            
            if (content.Length > 0)
            {
                var preview = content.Length > 150 ? content.Substring(0, 150) + "..." : content;
                AddLog($"响应预览: {preview}", "debug");
            }
            
            if (response.IsSuccessStatusCode)
            {
                AddLog("步骤 4: 解析响应...", "info");
                
                try
                {
                    var result = System.Text.Json.JsonSerializer.Deserialize<LoginResponse>(content);
                    
                    if (result != null)
                    {
                        AddLog($"解析结果: Success={result.Success}", "info");
                        
                        if (result.Success && !string.IsNullOrEmpty(result.AccessToken))
                        {
                            var tokenPreview = result.AccessToken.Length > 30 
                                ? result.AccessToken.Substring(0, 30) + "..." 
                                : result.AccessToken;
                            AddLog($"Token: {tokenPreview}", "success");
                            
                            // 保存到 localStorage
                            AddLog("步骤 5: 保存登录状态...", "info");
                            await JSRuntime.InvokeVoidAsync("localStorage.setItem", "authToken", result.AccessToken);
                            await JSRuntime.InvokeVoidAsync("localStorage.setItem", "user", 
                                System.Text.Json.JsonSerializer.Serialize(result.User));
                            
                            AddLog("登录成功！正在跳转...", "success");
                            
                            await Task.Delay(800);
                            Navigation.NavigateTo("/documents", forceLoad: true);
                        }
                        else
                        {
                            AddLog($"登录失败: {result.ErrorMessage}", "error");
                            errorMessage = result.ErrorMessage ?? "登录失败";
                        }
                    }
                    else
                    {
                        AddLog("解析结果为 null", "error");
                        errorMessage = "响应解析失败";
                    }
                }
                catch (Exception ex)
                {
                    AddLog($"解析异常: {ex.Message}", "error");
                    errorMessage = $"解析失败: {ex.Message}";
                }
            }
            else
            {
                AddLog($"请求失败: {response.StatusCode}", "error");
                errorMessage = $"登录失败 ({response.StatusCode}): {content}";
            }
        }
        catch (Exception ex)
        {
            AddLog($"顶层异常: {ex.GetType().Name}", "error");
            AddLog($"异常消息: {ex.Message}", "error");
            errorMessage = $"登录失败: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            AddLog("===== 登录流程结束 =====", "info");
            StateHasChanged();
        }
    }
    
    private void QuickLoginAdmin()
    {
        email = "admin@cwflgma.com";
        password = "Admin@123456";
        AddLog("已填充管理员账号", "info");
        StateHasChanged();
    }
    
    private void QuickLoginDemo()
    {
        email = "demo@cwflgma.com";
        password = "Demo@123456";
        AddLog("已填充演示账号", "info");
        StateHasChanged();
    }
    
    private class DebugLog
    {
        public string Time { get; set; } = "";
        public string Message { get; set; } = "";
        public string Type { get; set; } = "info";
    }
    
    private class LoginResponse
    {
        [System.Text.Json.Serialization.JsonPropertyName("success")]
        public bool Success { get; set; }
        
        [System.Text.Json.Serialization.JsonPropertyName("accessToken")]
        public string? AccessToken { get; set; }
        
        [System.Text.Json.Serialization.JsonPropertyName("refreshToken")]
        public string? RefreshToken { get; set; }
        
        [System.Text.Json.Serialization.JsonPropertyName("user")]
        public UserInfo? User { get; set; }
        
        [System.Text.Json.Serialization.JsonPropertyName("errorMessage")]
        public string? ErrorMessage { get; set; }
    }
    
    private class UserInfo
    {
        [System.Text.Json.Serialization.JsonPropertyName("id")]
        public long Id { get; set; }
        
        [System.Text.Json.Serialization.JsonPropertyName("username")]
        public string? Username { get; set; }
        
        [System.Text.Json.Serialization.JsonPropertyName("email")]
        public string? Email { get; set; }
        
        [System.Text.Json.Serialization.JsonPropertyName("displayName")]
        public string? DisplayName { get; set; }
    }
}
